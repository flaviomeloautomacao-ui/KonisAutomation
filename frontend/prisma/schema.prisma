// Prisma Schema — Automação de Laudos Técnicos
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth ─────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String   // bcrypt hash
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

// ─── Enums ────────────────────────────────────────────────

enum JobStatus {
  queued
  awaiting_complement
  processing
  done
  error
}

enum DocumentType {
  dha
  areas
}

enum DocumentSchemaVersion {
  legacy
  v2
}

// ─── Models ───────────────────────────────────────────────

model Job {
  id           String    @id @default(uuid()) @db.Uuid
  filename     String?
  profile      String    // ex: "dust", "gas", "vapors"
  documentType DocumentType? @map("document_type")
  documentSchemaVersion DocumentSchemaVersion @default(legacy) @map("document_schema_version")
  status       JobStatus @default(queued)
  progress     Int?      @default(0) // 0-100
  currentStep  String?   @map("current_step") // etapa legível: "Gerando recomendações…"
  rowCount     Int?      @map("row_count")
  errorCode    String?   @map("error_code")
  errorMessage String?   @map("error_message")

  // Arquivo clonado no Supabase Storage
  archivePath      String?   @map("archive_path")
  archiveExpiresAt DateTime? @map("archive_expires_at")

  // PDF gerado pelo serviço Python
  pdfPath    String?   @map("pdf_path")
  startedAt  DateTime? @map("started_at")
  finishedAt DateTime? @map("finished_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // ─── Observabilidade LLM (v2) ────────────────────────────
  inputHash          String?   @unique @map("input_hash")
  llmCostUsd         Float?    @map("llm_cost_usd")
  llmTotalTokens     Int?      @map("llm_total_tokens")
  llmCallCount       Int?      @map("llm_call_count")
  pipelineVersionId  String?   @map("pipeline_version_id")
  dedupSourceJobId   String?   @map("dedup_source_job_id") @db.Uuid

  // Relações
  spreadsheetUpload     SpreadsheetUpload?
  dhaSpreadsheetUpload  DhaSpreadsheetUpload?
  areaSpreadsheetUpload AreaSpreadsheetUpload?
  steps                 JobStep[]
  report                Report?
  llmUsageLogs          LlmUsageLog[]
  pipelineVersion       PipelineVersion?     @relation(fields: [pipelineVersionId], references: [id])
  dedupSourceJob        Job?                 @relation("JobDedup", fields: [dedupSourceJobId], references: [id])
  dedupDerivedJobs      Job[]                @relation("JobDedup")

  @@map("jobs")
}

model JobStep {
  id           String    @id @default(uuid()) @db.Uuid
  jobId        String    @map("job_id") @db.Uuid
  name         String    // ex: "upload_validation", "llm_analysis"
  label        String    // ex: "Validação do Upload", "Análise LLM"
  status       JobStatus @default(queued)
  order        Int       // sequência: 1, 2, 3…
  startedAt    DateTime? @map("started_at")
  completedAt  DateTime? @map("completed_at")
  errorMessage String?   @map("error_message")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relações
  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@map("job_steps")
}

model SpreadsheetUpload {
  id               String @id @default(uuid()) @db.Uuid
  jobId            String @unique @map("job_id") @db.Uuid
  originalFilename String @map("original_filename")
  mimeType         String @map("mime_type")
  size             Int    // tamanho em bytes
  rowCount         Int    @map("row_count")
  metadata         Json?  // { projeto, data, revisao }

  createdAt DateTime @default(now()) @map("created_at")

  // Relações
  job  Job                @relation(fields: [jobId], references: [id], onDelete: Cascade)
  rows SpreadsheetRow[]

  @@map("spreadsheet_uploads")
}

model SpreadsheetRow {
  id                   String  @id @default(uuid()) @db.Uuid
  uploadId             String  @map("upload_id") @db.Uuid
  rowIndex             Int     @map("row_index")
  equipmentName        String? @map("equipment_name")
  equipmentDescription String? @map("equipment_description")
  rawJson              Json    @map("raw_json")
  normalizedJson       Json    @map("normalized_json")

  createdAt DateTime @default(now()) @map("created_at")

  // Relações
  upload SpreadsheetUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@index([uploadId])
  @@map("spreadsheet_rows")
}

// ─── Report & Equipments ──────────────────────────────────

model Report {
  id        String   @id @default(uuid()) @db.Uuid
  jobId     String   @unique @map("job_id") @db.Uuid

  // Dados gerais do relatório (capa)
  razaoSocial          String?   @map("razao_social")
  cnpj                 String?
  site                 String?
  endereco             String?
  localVistoriado      String?   @map("local_vistoriado")
  dataAvaliacao        DateTime? @map("data_avaliacao")
  contrato             String?
  elaboracao           String?
  responsavel          String?
  registroProfissional String?   @map("registro_profissional")
  observacoesGerais       String?   @map("observacoes_gerais") @db.Text
  observacoesGeraisPrompt String?   @map("observacoes_gerais_prompt") @db.Text

  // Feature 1: Imagem de Capa
  coverImageUrl      String?   @map("cover_image_url")
  coverImagePublicId String?   @map("cover_image_public_id")

  // Feature 5: Encerramento
  artNumero       String?   @map("art_numero")
  codigoDocumento String?   @map("codigo_documento")

  // Áreas — campos extras para o template Project-Explo (Fase 2)
  escopoComplementar  String? @map("escopo_complementar") @db.Text
  tipoUnidade         String? @map("tipo_unidade")
  equipeResponsavel   Json?   @map("equipe_responsavel")
  equipeProjectExplo  Json?   @map("equipe_project_explo")
  artPdfUrl           String? @map("art_pdf_url")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relações
  job              Job                @relation(fields: [jobId], references: [id], onDelete: Cascade)
  equipments       ReportEquipment[]
  dhaEquipments    DhaReportEquipment[]
  areaReportAreas  AreaReportArea[]
  areaSubstances   AreaReportSubstance[]
  areaReferences   AreaReferenceDocument[]
  revisions        ReportRevision[]

  @@map("reports")
}

model ReportRevision {
  id          String   @id @default(uuid()) @db.Uuid
  reportId    String   @map("report_id") @db.Uuid
  version     String   // ex: "00", "01", "02"
  date        String   // ex: "24/03/2026"
  author      String   // ex: "Eng. Francisco Flávio Melo Cavalcante"
  description String   // ex: "Emissão inicial"

  createdAt DateTime @default(now()) @map("created_at")

  // Relações
  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@map("report_revisions")
}

model ReportEquipment {
  id       String @id @default(uuid()) @db.Uuid
  reportId String @map("report_id") @db.Uuid

  equipmentName        String  @map("equipment_name")
  equipmentDescription String? @map("equipment_description")
  orderIndex           Int     @map("order_index")

  // Dados extras (complementação do usuário)
  localInstalacao   String? @map("local_instalacao")
  funcaoOperacional String? @map("funcao_operacional")
  observacoesExtras String? @map("observacoes_extras") @db.Text
  extraJson         Json?   @map("extra_json")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relações
  report Report           @relation(fields: [reportId], references: [id], onDelete: Cascade)
  images EquipmentImage[]

  @@index([reportId])
  @@map("report_equipments")
}

model EquipmentImage {
  id          String @id @default(uuid()) @db.Uuid
  equipmentId String @map("equipment_id") @db.Uuid

  publicId  String @map("public_id")
  secureUrl String @map("secure_url")
  width     Int?
  height    Int?

  createdAt DateTime @default(now()) @map("created_at")

  // Relações
  equipment ReportEquipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@index([equipmentId])
  @@map("equipment_images")
}

model DhaSpreadsheetUpload {
  id               String @id @default(uuid()) @db.Uuid
  jobId            String @unique @map("job_id") @db.Uuid
  originalFilename String @map("original_filename")
  mimeType         String @map("mime_type")
  size             Int
  rowCount         Int    @map("row_count")
  metadata         Json?

  createdAt DateTime @default(now()) @map("created_at")

  job  Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  rows DhaSpreadsheetRow[]

  @@map("dha_spreadsheet_uploads")
}

model DhaSpreadsheetRow {
  id                   String  @id @default(uuid()) @db.Uuid
  uploadId             String  @map("upload_id") @db.Uuid
  rowIndex             Int     @map("row_index")
  equipmentName        String? @map("equipment_name")
  equipmentDescription String? @map("equipment_description")
  rawJson              Json    @map("raw_json")
  normalizedJson       Json    @map("normalized_json")

  createdAt DateTime @default(now()) @map("created_at")

  upload DhaSpreadsheetUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@index([uploadId])
  @@map("dha_spreadsheet_rows")
}

model DhaReportEquipment {
  id       String @id @default(uuid()) @db.Uuid
  reportId String @map("report_id") @db.Uuid

  equipmentName        String  @map("equipment_name")
  equipmentDescription String? @map("equipment_description")
  orderIndex           Int     @map("order_index")

  localInstalacao   String? @map("local_instalacao")
  funcaoOperacional String? @map("funcao_operacional")
  observacoesExtras String? @map("observacoes_extras") @db.Text
  extraJson         Json?   @map("extra_json")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  report Report             @relation(fields: [reportId], references: [id], onDelete: Cascade)
  images DhaEquipmentImage[]

  @@index([reportId])
  @@map("dha_report_equipments")
}

model DhaEquipmentImage {
  id          String @id @default(uuid()) @db.Uuid
  equipmentId String @map("equipment_id") @db.Uuid

  publicId  String @map("public_id")
  secureUrl String @map("secure_url")
  width     Int?
  height    Int?

  createdAt DateTime @default(now()) @map("created_at")

  equipment DhaReportEquipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@index([equipmentId])
  @@map("dha_equipment_images")
}

model AreaSpreadsheetUpload {
  id               String @id @default(uuid()) @db.Uuid
  jobId            String @unique @map("job_id") @db.Uuid
  originalFilename String @map("original_filename")
  mimeType         String @map("mime_type")
  size             Int
  rowCount         Int    @map("row_count")
  metadata         Json?

  createdAt DateTime @default(now()) @map("created_at")

  job  Job                @relation(fields: [jobId], references: [id], onDelete: Cascade)
  rows AreaSpreadsheetRow[]

  @@map("area_spreadsheet_uploads")
}

model AreaSpreadsheetRow {
  id                         String  @id @default(uuid()) @db.Uuid
  uploadId                   String  @map("upload_id") @db.Uuid
  rowIndex                   Int     @map("row_index")
  areaLocal                  String  @map("area_local")
  tagReferencia              String? @map("tag_referencia")
  substancia                 String
  fonteLiberacao             String  @map("fonte_liberacao")
  grauLiberacao              String  @map("grau_liberacao")
  ventilacaoTipo             String  @map("ventilacao_tipo")
  grauVentilacao             String  @map("grau_ventilacao")
  disponibilidadeVentilacao  String  @map("disponibilidade_ventilacao")
  zona                       String
  extensao                   String
  grupo                      String?
  classeTemperatura          String? @map("classe_temperatura")
  epl                        String?
  observacoes                String? @db.Text
  temperaturaProcesso        String? @map("temperatura_processo")
  pressaoProcesso            String? @map("pressao_processo")
  volumeProcesso             String? @map("volume_processo")
  rawJson                    Json    @map("raw_json")
  normalizedJson             Json    @map("normalized_json")

  createdAt DateTime @default(now()) @map("created_at")

  upload AreaSpreadsheetUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@index([uploadId])
  @@map("area_spreadsheet_rows")
}

model AreaReportArea {
  id                  String @id @default(uuid()) @db.Uuid
  reportId            String @map("report_id") @db.Uuid
  areaName            String @map("area_name")
  orderIndex          Int    @map("order_index")
  description         String? @db.Text
  operationalNotes    String? @map("operational_notes") @db.Text
  ventilationPremises String? @map("ventilation_premises") @db.Text
  extraJson           Json?   @map("extra_json")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  report  Report               @relation(fields: [reportId], references: [id], onDelete: Cascade)
  sources AreaReportSource[]
  photos  AreaReportAreaImage[]

  @@index([reportId])
  @@map("area_report_areas")
}

model AreaReportAreaImage {
  id        String @id @default(uuid()) @db.Uuid
  areaId    String @map("area_id") @db.Uuid

  publicId  String @map("public_id")
  secureUrl String @map("secure_url")
  width     Int?
  height    Int?
  caption   String?

  createdAt DateTime @default(now()) @map("created_at")

  area AreaReportArea @relation(fields: [areaId], references: [id], onDelete: Cascade)

  @@index([areaId])
  @@map("area_report_area_images")
}

model AreaReportSource {
  id                        String @id @default(uuid()) @db.Uuid
  areaId                    String @map("area_id") @db.Uuid
  orderIndex                Int    @map("order_index")
  tagReferencia             String? @map("tag_referencia")
  substanceName             String  @map("substance_name")
  sourceName                String  @map("source_name")
  liberationDegree          String  @map("liberation_degree")
  ventilationType           String  @map("ventilation_type")
  ventilationDegree         String  @map("ventilation_degree")
  ventilationAvailability   String  @map("ventilation_availability")
  zone                      String
  extension                 String
  grupo                     String?
  classeTemperatura         String? @map("classe_temperatura")
  epl                       String?
  temperaturaProcesso       String? @map("temperatura_processo")
  pressaoProcesso           String? @map("pressao_processo")
  volumeProcesso            String? @map("volume_processo")
  notes                     String? @db.Text
  extraJson                 Json?   @map("extra_json")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  area AreaReportArea @relation(fields: [areaId], references: [id], onDelete: Cascade)

  @@index([areaId])
  @@map("area_report_sources")
}

model AreaReportSubstance {
  id                 String @id @default(uuid()) @db.Uuid
  reportId           String @map("report_id") @db.Uuid
  substanceName      String @map("substance_name")
  orderIndex         Int    @map("order_index")
  grupo              String?
  classeTemperatura  String? @map("classe_temperatura")
  epl                String?
  propertiesJson     Json?   @map("properties_json")
  notes              String? @db.Text

  // Campos físico-químicos explícitos para a Tabela 1 (Fase 2)
  // tipo: "gas_vapor" | "poeira_fibra" — controla qual tabela renderizar
  tipo               String?
  pontoFulgor        String? @map("ponto_fulgor")
  lii                String?
  densidadeRelativa  String? @map("densidade_relativa")
  tai                String?
  cme                String?
  mit                String?
  sitCamada          String? @map("sit_camada")
  tmax               String?
  st                 String?
  legendNotes        String[] @map("legend_notes")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@map("area_report_substances")
}

model AreaReferenceDocument {
  id           String @id @default(uuid()) @db.Uuid
  reportId     String @map("report_id") @db.Uuid
  orderIndex   Int    @map("order_index")
  title        String
  documentCode String? @map("document_code")
  documentUrl  String? @map("document_url")
  notes        String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@map("area_reference_documents")
}

// ─── Tabelas pré-existentes (Supabase) ────────────────────

/// Esta tabela já existia no Supabase (não gerenciada por migrations).
/// Contains row level security. See: https://pris.ly/d/row-level-security
model konis_db {
  id        BigInt                 @id @default(autoincrement())
  content   String?
  metadata  Json?
  embedding Unsupported("vector")?
}

model konis_db_DHA {
  id        BigInt                 @id @default(autoincrement())
  content   String?
  metadata  Json?
  embedding Unsupported("vector")?
}

model konis_db_ClassificacaoDeAreas {
  id        BigInt                 @id @default(autoincrement())
  content   String?
  metadata  Json?
  embedding Unsupported("vector")?
}

// ─── Observabilidade LLM (v2) ─────────────────────────────

model LlmUsageLog {
  id               String   @id @default(uuid()) @db.Uuid
  jobId            String   @map("job_id") @db.Uuid

  flow             String
  step             String
  provider         String
  model            String
  callType         String   @map("call_type")

  inputTokens      Int      @default(0) @map("input_tokens")
  outputTokens     Int      @default(0) @map("output_tokens")
  totalTokens      Int      @default(0) @map("total_tokens")
  tokensSource     String   @default("estimate") @map("tokens_source")

  estimatedCostUsd Float    @default(0.0) @map("estimated_cost_usd")
  durationMs       Float    @default(0.0) @map("duration_ms")

  success          Boolean  @default(true)
  errorMessage     String?  @map("error_message") @db.Text
  retryAttempt     Int?     @map("retry_attempt")

  equipmentName    String?  @map("equipment_name")

  promptChars      Int      @default(0) @map("prompt_chars")
  responseChars    Int      @default(0) @map("response_chars")

  createdAt        DateTime @default(now()) @map("created_at")

  job              Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([jobId, step])
  @@index([createdAt])
  @@map("llm_usage_logs")
}

model PipelineVersion {
  id               String   @id @default(cuid())

  promptVersion    String   @map("prompt_version")
  schemaVersion    String   @map("schema_version")
  ragStrategy      String   @map("rag_strategy")
  llmModel         String   @map("llm_model")
  embeddingModel   String   @map("embedding_model")

  promptHash       String   @map("prompt_hash")
  schemaHash       String   @map("schema_hash")

  ragTopK          Int      @map("rag_top_k")
  ragMaxChunks     Int      @map("rag_max_chunks")
  ragMinScore      Float    @map("rag_min_score")

  configSnapshot   Json     @map("config_snapshot")
  createdAt        DateTime @default(now()) @map("created_at")

  jobs             Job[]

  @@index([promptHash, schemaHash])
  @@map("pipeline_versions")
}
