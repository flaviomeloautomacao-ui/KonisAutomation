# App/domain
NEXT_PUBLIC_APP_URL=https://app.seu-dominio.com
NEXTAUTH_URL=https://app.seu-dominio.com
AUTH_SECRET=troque-por-uma-chave-forte

# Admin seed (bootstrap no start do container; cria só se não existir).
# Deixe email/senha em branco para desativar.
SEED_ADMIN_EMAIL=admin@seu-dominio.com
SEED_ADMIN_PASSWORD=troque-esta-senha
SEED_ADMIN_NAME=Administrador

# Internal service URL used by the Next.js server routes.
# In Docker/Dokploy it must stay as backend:8000.
PYTHON_SERVICE_URL=http://backend:8000
INTERNAL_API_KEY=

# Database URLs
# Frontend/Prisma uses the normal Postgres URL.
FRONTEND_DATABASE_URL=postgresql://postgres:senha@host:5432/automacao
# Backend/SQLAlchemy async uses the asyncpg dialect.
BACKEND_DATABASE_URL=postgresql+asyncpg://postgres:senha@host:5432/automacao

# Supabase
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=documents
REPORTS_BUCKET=reports

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# OpenRouter / LLM
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-4o

# Runtime
ENV=production
API_PORT=8000
FRONTEND_PORT=3000
BACKEND_PORT=8000
